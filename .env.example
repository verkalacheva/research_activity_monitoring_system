# ---------------------------------------------------------------------------
# Docker: БД, Redis, health, публикация портов
# ---------------------------------------------------------------------------
DB_PASSWORD=""                    # Пароль postgres; DSN в сервисах
SECRET_KEY_BASE=""                 # Rails
API_BASE_URL=""                    # URL API для Flutter: с точки зрения браузера или https://домен
HEALTHCHECK_HOST=""                # Для healthcheck внутри контейнера
REDIS_URL=""                       # Sidekiq, кэш, кабель по умолчанию
CRAWL_REDIS_URL=""                 # Краулер: офлайн-индекс, очереди
CABLE_REDIS_URL=""                # Action Cable; 
BACKEND_PUBLISH_PORT=3000         # host → backend:3000 
FRONTEND_PUBLISH_PORT=8080         # host → frontend:8080;

# ---------------------------------------------------------------------------
# Rails 
# ---------------------------------------------------------------------------
RAILS_LOG_TO_STDOUT=true           # Логи в stdout (Docker)
RAILS_LOG_LEVEL=info
PORT=3000
WEB_CONCURRENCY=0
RAILS_MAX_THREADS=5
RAILS_MIN_THREADS=""               # Пусто = как max threads
DB_HOST=db
DB_USERNAME=postgres

# gRPC: backend → сервисы (секунды / мс)
GRPC_INTEGRATION_DEADLINE_SECONDS=120
GRPC_ANALYTICS_DEADLINE_SECONDS=90
GRPC_CRAWL_DEADLINE_SECONDS=3600      # Дедлайн Rails → краулер; краулер работает без внутреннего лимита
GRPC_KEEPALIVE_TIME_MS=300000
GRPC_KEEPALIVE_TIMEOUT_MS=10000
GRPC_KEEPALIVE_PERMIT_WITHOUT_CALLS=0
GRPC_HTTP2_MAX_PINGS_WITHOUT_DATA=0

# Хосты gRPC (типичная docker-сеть; меняйте при не-Compose окружении)
ANALYTICS_SERVICE_HOST=analytics:50051
INTEGRATION_SERVICE_HOST=integration:50052
CRAWLER_SERVICE_HOST=crawler:50053

# Ежедневная синхронизация / предпросмотр
DAILY_SYNC_EXCLUDE_CRAWL=false     # true — без LLM-краулера в daily job
DAILY_CRAWL_CONCURRENCY=4         # Параллелизм sync preview (backend)

# ---------------------------------------------------------------------------
# Краулер (Python):
# ---------------------------------------------------------------------------
LITELLM_NUM_RETRIES=0
LLM_RPM=4
LLM_CONCURRENCY=1
CRAWL_CONCURRENCY=5
CRAWL_INTER_URL_DELAY_SEC=15
CRAWL_MAX_URLS_PER_SYNC=""        # 0 или пусто = без лимита URL за прогон
CRAWL_ENABLE_CATALOG_FETCH=1
CRAWL_ORCID_PROFILE_URL=1
CRAWL_AUDIT_LOG=""                # Путь к логу аудита; пусто = не писать
CRAWL_PIPELINE_ENABLED=1
CRAWL_RETRIEVAL_ENABLED=1
CRAWL_MAX_RETRIEVAL_PROMPT_CHARS=16000

# ddgs web search (из Docker CDN-IP часто отваливается html.duckduckgo и Yahoo — см. crawler_service/infrastructure/search_client.py)
# DDGS_PROXY=http://proxy:8118   # при необходимости
DDGS_TIMEOUT=25
CRAWL_DDGS_BACKEND=bing,mojeek,brave
CRAWL_DDGS_FALLBACK_BACKENDS=google,duckduckgo

# ---------------------------------------------------------------------------
# Go-сервисы:
# ---------------------------------------------------------------------------
# DATABASE_URL, PORT, HEALTH_HTTP_PORT
