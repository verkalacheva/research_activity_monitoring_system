FROM python:3.10-slim-bookworm

WORKDIR /app

# Install system dependencies for Playwright
RUN rm -rf /var/lib/apt/lists/* \
    && apt-get clean \
    && apt-get update \
    && apt-get install -y \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    curl \
    gnupg \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Install CPU-only torch first to prevent pip from pulling multi-GB CUDA wheels.
# crawl4ai has sentence-transformers as a base dep which requires torch, and pip
# on Linux defaults to CUDA builds from PyPI without this override.
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# Install python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browsers and dependencies for Crawl4AI
RUN python -m playwright install --with-deps chromium

COPY . .

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PORT=50053

CMD ["python", "main.py"]
